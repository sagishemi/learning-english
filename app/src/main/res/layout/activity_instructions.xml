<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/game_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/txtInstructionsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How to Play"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/button_background"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Select an English word from the left column."
                android:textSize="16sp"
                android:textColor="#475569"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Find its Hebrew translation in the right column."
                android:textSize="16sp"
                android:textColor="#475569"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Match correctly to earn 10 points!"
                android:textSize="16sp"
                android:textColor="#059669"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4. If you miss, you lose 5 points."
                android:textSize="16sp"
                android:textColor="#DC2626"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The AI will provide new words once you finish the set."
                android:textSize="14sp"
                android:textColor="#64748B"
                android:fontStyle="italic"
                android:layout_marginTop="16dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnStartFromInstructions"
            style="@style/GameButtonStyle"
            android:background="@drawable/button_selected"
            android:textColor="#FFFFFF"
            android:text="Start Now!"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
